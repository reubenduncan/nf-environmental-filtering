params {
    // ---- Input / Output ------------------------------------------------
    feature_table        = "${projectDir}/data/feature_table.biom"
    meta_table           = "${projectDir}/data/meta_table.csv"
    taxonomy_table       = ""                   // required if input_format != biom
    tree_file            = ""                   // required by ENV_FILTERING and QPE
    input_format         = "biom"               // biom | tsv | gtdb
    output_dir           = "${projectDir}/results"

    // ---- Filtering -----------------------------------------------------
    min_library_size     = 5000
    exclude_column       = ""
    exclude_values       = ""

    // ---- Grouping ------------------------------------------------------
    group                = ""          // one column, or comma-sep columns to paste as Groups
    type                 = ""          // optional: metadata column for Type annotation
    type2                = ""          // optional: metadata column for Type2 annotation (EF only)

    // ---- Analysis label ------------------------------------------------
    label                = "analysis"

    // ---- NRI/NTI (environmental filtering) -----------------------------
    ef_runs              = 999
    ef_iterations        = 1000
    ef_top_n_features        = 2000
    ef_null_model        = "trialswap"          // taxa.labels|richness|frequency|sample.pool|phylogeny.pool|independentswap|trialswap
    ef_abundance_weighted = true
    ef_test_method       = "anova"              // anova | kruskal | none
    ef_p_adjust_method   = "BH"                 // BH | bonferroni | holm | none

    // ---- NST -----------------------------------------------------------
    nst_randomizations   = 1000
    nst_distance         = "cao"                // bray | jaccard | cao | chao
    nst_null_model       = "PF"                 // EE|EP|EF|PE|PP|PF|FE|FP|FF
    nst_abundance_weighted = false
    nst_ses              = true
    nst_rc               = false

    // ---- QPE -----------------------------------------------------------
    qpe_beta_reps        = 999
    qpe_ems_sims         = 999
    qpe_ordering         = ""                   // comma-separated group ordering; empty = alphabetical

    // ---- Skip flags ----------------------------------------------------
    skip_ef              = false   // skip NRI/NTI (ENV_FILTERING)
    skip_nst             = false   // skip NST stochasticity analysis
    skip_qpe             = false   // skip QPE + QPE_SUMMARY

    // ---- Resources -----------------------------------------------------
    max_cpus             = 4                    // threads for QPE betaNTI (PSOCK cluster); scale freely with HPC cores
    nst_workers          = 4                    // tNST nworker; each worker holds a full distance matrix copy — keep low

    // ---- Output --------------------------------------------------------
    merge_parquet        = false                // merge all CSVs into one parquet after analyses complete
}

// ---- Default: conda --------------------------------------------------------
conda.enabled  = true
docker.enabled = false

process {
    conda = "${projectDir}/environment.yml"

    withName: 'ENV_FILTERING' {
        cpus   = Math.min(params.max_cpus as int, 2)   // ses.mpd + ses.mntd run as 2 parallel forks
        memory = '8 GB'
        time   = '120 h'
    }

    withName: 'QPE' {
        cpus   = params.max_cpus as int
        memory = '8 GB'
        time   = '120 h'
    }

    withName: 'NST' {
        cpus   = params.nst_workers as int
        memory = '4 GB'
        time   = '120 h'
    }

    withName: 'QPE_SUMMARY' {
        cpus   = 1
        memory = '2 GB'
        time   = '30 min'
    }

    withName: 'MERGE_PARQUET' {
        cpus   = 1
        memory = '4 GB'
        time   = '15 min'
    }
}

profiles {
    conda {
        conda.enabled  = true
        docker.enabled = false
    }
    docker {
        conda.enabled     = false
        docker.enabled    = true
        docker.runOptions = "-u \$(id -u):\$(id -g) -v ${projectDir}:${projectDir}:ro"
        process {
            container = 'reubenduncan/ecologyflow-ef:latest'
        }
    }
    singularity {
        conda.enabled          = false
        singularity.enabled    = true
        singularity.autoMounts = true
        process {
            container = 'docker://reubenduncan/ecologyflow-ef:latest'
        }
    }
}

manifest {
    name        = 'environmental-filtering'
    description = 'Environmental filtering analysis: NRI/NTI, NST, and QPE/metacommunity structure'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}
